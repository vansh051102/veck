# =============================================================================
# REQUIRED — the app will not run correctly without these
# =============================================================================

# Supabase (project URL + keys from Settings → API)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Server-side only. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Database. Prisma CLI reads this via `npm run db:*`, which sources .env.local.
# Quote the URL — an & in the query string breaks unquoted shell sourcing.
# For Supabase use the pooled connection string (port 5432).
#
# Include connection_limit and pool_timeout in the query string, e.g.
#   ?connection_limit=15&pool_timeout=20
# A handful of routes (GET /api/v1/leads/stats in particular) fan out several
# queries per request. Prisma's default connection_limit is quite small for a
# serverless deployment with any concurrent traffic — too few connections for
# even one such request means every additional concurrent user queues behind
# Prisma's 10s pool_timeout and starts failing with 503s. Load-tested and
# documented in tests/load/k6-baseline.js.
DATABASE_URL="your_database_url"

# Protects /api/v1/cron/* — callers send `Authorization: Bearer <CRON_SECRET>`.
# Use a random string of 32+ characters.
CRON_SECRET=your_cron_secret

# =============================================================================
# OPTIONAL — features degrade quietly when unset
# =============================================================================

# Transactional email (SLA breach + warning notifications). Unset means
# lib/sla-email.ts silently no-ops and no SLA mail is ever delivered.
# RESEND_API_KEY=your_resend_api_key

# Base URL used to build links in generated emails and admin quick-login
# magic links. Defaults to https://app.veck.in when unset.
# APP_URL=http://localhost:3000

# pino log level (trace|debug|info|warn|error). Defaults to debug in
# development and info in production.
# LOG_LEVEL=info

# Direct (non-pooled) connection, used only for migrations. Not read by the
# app today — add it to the datasource block in prisma/schema.prisma if
# `prisma migrate deploy` hangs on advisory locks through the Supabase pooler.
# See docs/database-migrations.md.
# DIRECT_URL="your_direct_database_url"

# =============================================================================
# ENVIRONMENT
# =============================================================================

NODE_ENV=development

# =============================================================================
# DEV ONLY — must never be true in production
# =============================================================================

# Skips the login gate entirely and impersonates the first admin user
# (lib/dev-auth.ts). Setting either to true in a deployed environment disables
# authentication for everyone. Keep false to use real Supabase auth.
DISABLE_AUTH=false
NEXT_PUBLIC_DISABLE_AUTH=false

# Auto-provisions an admin when the database is empty. Only consulted while
# DISABLE_AUTH=true (lib/dev-bootstrap.ts).
# DEV_ADMIN_EMAIL=dev@veck.local
# DEV_ADMIN_PASSWORD=devpassword123

# -----------------------------------------------------------------------------
# Note: integration secrets (IndiaMART, TradeIndia, WhatsApp, JustDial, email)
# are NOT environment variables. Each is stored per-organization on the Settings
# record and managed at Admin → Workspace → Integrations, so one deployment can
# serve many orgs with different credentials.
# -----------------------------------------------------------------------------
