# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Database
DATABASE_URL=your_database_url

# API
NEXT_PUBLIC_API_URL=http://localhost:3000

# Cron Jobs (Vercel Cron, GitHub Actions, etc.)
CRON_SECRET=your_cron_secret

# IndiaMART Webhook (required for lead ingestion)
# These MUST be set in production — no DB fallback for security.
INDIAMART_WEBHOOK_SECRET=your_indiamart_webhook_secret
INDIAMART_ORG_ID=your_org_id
INDIAMART_SYSTEM_USER_ID=your_system_user_id

# Environment
NODE_ENV=development
