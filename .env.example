# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Database (Prisma CLI reads via npm run db:* which loads .env.local)
# Quote the URL — & in query strings breaks unquoted shell sourcing.
DATABASE_URL="your_database_url"
DIRECT_URL="your_direct_database_url"

# API
NEXT_PUBLIC_API_URL=http://localhost:3000

# Cron Jobs (Vercel Cron, GitHub Actions, etc.)
CRON_SECRET=your_cron_secret

# IndiaMART Webhook (required for lead ingestion)
# These MUST be set in production — no DB fallback for security.
INDIAMART_WEBHOOK_SECRET=your_indiamart_webhook_secret
INDIAMART_ORG_ID=your_org_id
INDIAMART_SYSTEM_USER_ID=your_system_user_id

# Environment
NODE_ENV=development

# Dev only — skip login gate and impersonate first admin user (NEVER in production)
# Keep false for real Supabase auth. Set both to true only for local bypass.
DISABLE_AUTH=false
NEXT_PUBLIC_DISABLE_AUTH=false
# Optional auto-provision when DB is empty (only used with DISABLE_AUTH=true)
# DEV_ADMIN_EMAIL=dev@veck.local
# DEV_ADMIN_PASSWORD=devpassword123
